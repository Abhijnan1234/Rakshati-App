# Root reference example for local development.
# Backend services read variables from backend/.env.
# Flutter reads values passed with --dart-define.

# Backend
PORT=5000
MONGODB_URI=your_mongodb_atlas_connection_string
JWT_SECRET=replace_with_a_long_random_secret
NODE_ENV=development
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# Mobile Flutter dart-defines
NETWORK_BASE_URL=http://10.0.2.2:5000
GOOGLE_SERVER_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
