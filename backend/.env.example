# Port used by the Express server locally.
PORT=5000

# MongoDB Atlas connection string for the Rakshati backend database.
MONGODB_URI=your_mongodb_atlas_connection_string

# JWT signing secret. Use a long random value in every environment.
JWT_SECRET=replace_with_a_long_random_secret

# Backend runtime mode.
NODE_ENV=development

# Firebase / Google web client ID used for backend token verification.
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
